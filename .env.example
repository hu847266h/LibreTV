# Cloudflare API 凭证（用于 npm run setup）
# 在 https://dash.cloudflare.com/profile/api-tokens 创建 Token
# 权限要求：Cloudflare Pages:Edit + Workers KV Storage:Edit + D1:Edit
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Pages 项目名称（可选，默认 libretv）
# CF_PROJECT_NAME=libretv

# KV / D1 自定义名称（可选，有默认值）
# CF_KV_NAME=LIBRETV_SESSIONS
# CF_D1_NAME=libretv-db

# 网站密码（CF Pages 环境变量中设置）
# PASSWORD=your_password_here
